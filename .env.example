# Copy to .env and fill in. All are optional in preview; required in production.

# Where captured leads are POSTed (your CRM inbound / lead-nurture webhook).
# Leave blank to log the payload to the browser console instead of sending.
VITE_LEAD_WEBHOOK_URL=

# Where the post-capture "Book a review" button links.
VITE_BOOKING_URL=https://huck.agency/book

# Privacy policy linked from the GDPR consent checkbox.
VITE_PRIVACY_URL=https://huck.agency/privacy
